{
  "info": {
    "name": "SyncVault API",
    "description": "SyncVault monorepo — User Service (8081) + File Service (8082)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "User Service",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const body = pm.response.json();",
                  "    pm.environment.set('user_id', body.userId);",
                  "    console.log('Registered user_id:', body.userId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@syncvault.com\",\n  \"password\": \"password123\",\n  \"fullName\": \"Test User\"\n}"
            },
            "url": {
              "raw": "{{user_base_url}}/auth/register",
              "host": ["{{user_base_url}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const body = pm.response.json();",
                  "    pm.environment.set('access_token', body.accessToken);",
                  "    pm.environment.set('refresh_token', body.refreshToken);",
                  "    console.log('access_token set:', body.accessToken.substring(0, 20) + '...');",
                  "    console.log('Expires in (s):', body.expiresIn);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@syncvault.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{user_base_url}}/auth/login",
              "host": ["{{user_base_url}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const body = pm.response.json();",
                  "    pm.environment.set('access_token', body.accessToken);",
                  "    pm.environment.set('refresh_token', body.refreshToken);",
                  "    console.log('Tokens rotated');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{user_base_url}}/auth/refresh",
              "host": ["{{user_base_url}}"],
              "path": ["auth", "refresh"]
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{user_base_url}}/auth/logout",
              "host": ["{{user_base_url}}"],
              "path": ["auth", "logout"]
            }
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{user_base_url}}/users/{{user_id}}/profile",
              "host": ["{{user_base_url}}"],
              "path": ["users", "{{user_id}}", "profile"]
            }
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Updated Name\"\n}"
            },
            "url": {
              "raw": "{{user_base_url}}/users/{{user_id}}/profile",
              "host": ["{{user_base_url}}"],
              "path": ["users", "{{user_id}}", "profile"]
            }
          }
        }
      ]
    },
    {
      "name": "File Service",
      "item": [
        {
          "name": "Upload File",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const body = pm.response.json();",
                  "    pm.environment.set('file_id', body.fileId);",
                  "    pm.environment.set('version_number', String(body.versionNumber));",
                  "    console.log('file_id set:', body.fileId);",
                  "    console.log('version:', body.versionNumber);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "",
                  "description": "Select a file to upload"
                },
                {
                  "key": "baseVersion",
                  "value": "",
                  "type": "text",
                  "disabled": true,
                  "description": "Leave empty for new upload"
                }
              ]
            },
            "url": {
              "raw": "{{file_base_url}}/files/upload",
              "host": ["{{file_base_url}}"],
              "path": ["files", "upload"]
            }
          }
        },
        {
          "name": "Get File",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{file_base_url}}/files/{{file_id}}",
              "host": ["{{file_base_url}}"],
              "path": ["files", "{{file_id}}"]
            }
          }
        },
        {
          "name": "List My Files",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{file_base_url}}/files/user/{{user_id}}",
              "host": ["{{file_base_url}}"],
              "path": ["files", "user", "{{user_id}}"]
            }
          }
        },
        {
          "name": "Update File",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const body = pm.response.json();",
                  "    if (body.newVersionNumber) {",
                  "        pm.environment.set('version_number', String(body.newVersionNumber));",
                  "        console.log('Updated to version:', body.newVersionNumber);",
                  "    }",
                  "} else if (pm.response.code === 409) {",
                  "    const body = pm.response.json();",
                  "    console.log('Conflict! conflict copy id:', body.conflictCopyId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "",
                  "description": "Updated file"
                },
                {
                  "key": "baseVersion",
                  "value": "{{version_number}}",
                  "type": "text",
                  "description": "Current version from env — must match server version to avoid conflict"
                }
              ]
            },
            "url": {
              "raw": "{{file_base_url}}/files/{{file_id}}",
              "host": ["{{file_base_url}}"],
              "path": ["files", "{{file_id}}"]
            }
          }
        },
        {
          "name": "Delete File",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{file_base_url}}/files/{{file_id}}",
              "host": ["{{file_base_url}}"],
              "path": ["files", "{{file_id}}"]
            }
          }
        },
        {
          "name": "Get Version History",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{file_base_url}}/files/{{file_id}}/versions",
              "host": ["{{file_base_url}}"],
              "path": ["files", "{{file_id}}", "versions"]
            }
          }
        },
        {
          "name": "Restore Version",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{file_base_url}}/files/{{file_id}}/versions/{{version_number}}/restore",
              "host": ["{{file_base_url}}"],
              "path": ["files", "{{file_id}}", "versions", "{{version_number}}", "restore"]
            }
          }
        },
        {
          "name": "Health Check",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": {
              "raw": "{{file_base_url}}/actuator/health",
              "host": ["{{file_base_url}}"],
              "path": ["actuator", "health"]
            }
          }
        }
      ]
    }
  ]
}
